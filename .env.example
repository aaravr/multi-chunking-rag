AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
OPENAI_API_KEY=
DATABASE_URL=
IDP_DATA_DIR=./data
DISABLE_DI=false
ENABLE_HYBRID_RETRIEVAL=false
ENABLE_VERIFIER=false
ENABLE_RERANKER=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ENABLE_REDIS_WORKING_MEMORY=true
REDIS_URL=redis://localhost:6379/0
REDIS_WORKING_MEMORY_TTL=900
ENABLE_KAFKA_BUS=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_REQUEST_TIMEOUT_MS=30000
# Producer tuning
KAFKA_COMPRESSION_TYPE=lz4
KAFKA_LINGER_MS=5
KAFKA_BATCH_SIZE=16384
KAFKA_ACKS=all
KAFKA_PRODUCER_RETRIES=5
# Consumer tuning
KAFKA_MAX_POLL_RECORDS=10
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=10000
KAFKA_FETCH_MIN_BYTES=1
# Resilience
KAFKA_CIRCUIT_BREAKER_THRESHOLD=5
KAFKA_CIRCUIT_BREAKER_COOLDOWN_S=60
KAFKA_RETRY_MAX_ATTEMPTS=3
KAFKA_RETRY_BASE_DELAY_S=1.0
KAFKA_RETRY_MAX_DELAY_S=30.0
KAFKA_ENABLE_DLQ=true
KAFKA_ENABLE_IDEMPOTENCY=true
KAFKA_IDEMPOTENCY_TTL_S=300
KAFKA_IDEMPOTENCY_MAX_ENTRIES=50000
# Security (SASL/TLS) — uncomment for production
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
# KAFKA_SSL_CAFILE=
# KAFKA_SSL_CERTFILE=
# KAFKA_SSL_KEYFILE=
# ── OpenTelemetry ──────────────────────────────────
ENABLE_OTEL=false
OTEL_EXPORTER_ENDPOINT=localhost:4317
OTEL_SERVICE_NAME=idp-agent
OTEL_SAMPLE_RATE=1.0
OTEL_EXPORT_CONSOLE=false
# ── Agent Evaluation ───────────────────────────────
ENABLE_AGENT_EVAL=false
AGENT_EVAL_LOG_DIR=eval_logs
